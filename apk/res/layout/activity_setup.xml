<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0f">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OWURA SETUP"
            android:textSize="24sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Step 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> Step 1: Install Termux"
            android:textSize="14sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download from F-Droid (not Play Store)"
            android:textSize="12sp"
            android:textColor="#00aa55"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnInstallTermux"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="[ Open F-Droid ]"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#1a1a2e"
            android:textColor="#00ff88"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step1Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="#00ff88"
            android:buttonTint="#00ff88"
            android:layout_marginBottom="24dp" />

        <!-- Step 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> Step 2: Install Termux:API"
            android:textSize="14sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="For hardware integration"
            android:textSize="12sp"
            android:textColor="#00aa55"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnInstallApi"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="[ Open F-Droid ]"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#1a1a2e"
            android:textColor="#00ff88"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step2Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="#00ff88"
            android:buttonTint="#00ff88"
            android:layout_marginBottom="24dp" />

        <!-- Step 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> Step 3: Clone OWURA"
            android:textSize="14sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCopyClone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="[ Copy Command ]"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#1a1a2e"
            android:textColor="#00ff88"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step3Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="#00ff88"
            android:buttonTint="#00ff88"
            android:layout_marginBottom="24dp" />

        <!-- Step 4 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> Step 4: Run Setup"
            android:textSize="14sp"
            android:textColor="#00ff88"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCopySetup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="[ Copy Command ]"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#1a1a2e"
            android:textColor="#00ff88"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step4Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="#00ff88"
            android:buttonTint="#00ff88"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#00ff88"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="[ BACK ]"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:backgroundTint="#1a1a2e"
            android:textColor="#00ff88"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
