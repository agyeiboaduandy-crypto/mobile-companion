<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup Wizard"
            android:textSize="24sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Step 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1: Install Termux"
            android:textSize="16sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download and install Termux from F-Droid (not Play Store)."
            android:textSize="14sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnInstallTermux"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open F-Droid"
            android:textSize="14sp"
            android:backgroundTint="#0f3460"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step1Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I have installed Termux"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp" />

        <!-- Step 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2: Install Termux:API"
            android:textSize="16sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Install Termux:API for hardware integration."
            android:textSize="14sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnInstallApi"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open F-Droid"
            android:textSize="14sp"
            android:backgroundTint="#0f3460"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step2Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I have installed Termux:API"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp" />

        <!-- Step 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 3: Clone Repository"
            android:textSize="16sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Termux and run:"
            android:textSize="14sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCopyClone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Copy Clone Command"
            android:textSize="14sp"
            android:backgroundTint="#533483"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step3Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I have cloned the repository"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp" />

        <!-- Step 4 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 4: Run Setup"
            android:textSize="16sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run the bootstrap script:"
            android:textSize="14sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCopySetup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Copy Setup Command"
            android:textSize="14sp"
            android:backgroundTint="#533483"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/step4Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup complete"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#4ecca3"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back"
            android:textSize="16sp"
            android:backgroundTint="#16213e"
            android:textColor="#ffffff" />

    </LinearLayout>
</ScrollView>
