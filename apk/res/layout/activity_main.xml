<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0A0A0F">

    <!-- Header: Neon Glow -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OWURA_OS v1.0"
        android:textSize="12sp"
        android:textColor="#00FF88"
        android:fontFamily="monospace"
        android:gravity="start"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=">> AI_CODING_AGENT"
        android:textSize="28sp"
        android:textColor="#00FF88"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Status Terminal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#11111B"
        android:padding="12dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/termuxStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SYS_LINK: CHECKING..."
            android:textSize="12sp"
            android:textColor="#00FF88"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AGENT_STATUS: INITIALIZING..."
            android:textSize="12sp"
            android:textColor="#00FF88"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Command Board -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="COMMAND_BOARD"
        android:textSize="14sp"
        android:textColor="#00AA55"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSetup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="[ EXEC_SETUP ]"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#0A0A0F"
        android:textColor="#00FF88"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnKeys"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="[ CONFIG_KEYS ]"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#0A0A0F"
        android:textColor="#00FF88"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnModels"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="[ SCAN_MODELS ]"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#0A0A0F"
        android:textColor="#00FF88"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOpenTermux"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text=">> INITIALIZE_SESSION"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:backgroundTint="#00FF88"
        android:textColor="#0A0A0F"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

</LinearLayout>
