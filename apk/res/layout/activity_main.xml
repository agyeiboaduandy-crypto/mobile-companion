<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mobile Companion"
        android:textSize="28sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Coding Station"
        android:textSize="16sp"
        android:textColor="#aaaaaa"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/termuxStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Termux: Checking..."
        android:textSize="14sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mobile Companion: Checking..."
        android:textSize="14sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSetup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Setup Wizard"
        android:textSize="16sp"
        android:backgroundTint="#e94560"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnKeys"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="API Keys"
        android:textSize="16sp"
        android:backgroundTint="#0f3460"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnModels"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Available Models"
        android:textSize="16sp"
        android:backgroundTint="#16213e"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOpenTermux"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Open Termux"
        android:textSize="16sp"
        android:backgroundTint="#533483"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp" />

</LinearLayout>
